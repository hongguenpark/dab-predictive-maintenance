{
  "datasets": [
    {
      "name": "ds_equip_vib",
      "displayName": "장비별 진동",
      "queryLines": [
        "SELECT e.equipment_name, ROUND(AVG(s.vibration_rms), 2) as avg_vibration FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.equipment_name ORDER BY avg_vibration DESC"
      ]
    },
    {
      "name": "ds_equip_temp",
      "displayName": "장비별 온도",
      "queryLines": [
        "SELECT e.equipment_name, ROUND(AVG(s.temperature_c), 1) as avg_temperature FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.equipment_name ORDER BY avg_temperature DESC"
      ]
    },
    {
      "name": "ds_status_counts",
      "displayName": "상태별 장비 수",
      "queryLines": [
        "WITH eq AS (SELECT e.equipment_id, CASE WHEN AVG(s.vibration_rms) > 10 OR AVG(s.temperature_c) > 90 THEN '긴급' WHEN AVG(s.vibration_rms) > 7 OR AVG(s.temperature_c) > 75 THEN '위험' WHEN AVG(s.vibration_rms) > 4.5 OR AVG(s.temperature_c) > 60 THEN '주의' ELSE '정상' END AS status FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.equipment_id) SELECT status, COUNT(*) as cnt FROM eq GROUP BY status ORDER BY CASE status WHEN '긴급' THEN 1 WHEN '위험' THEN 2 WHEN '주의' THEN 3 ELSE 4 END"
      ]
    },
    {
      "name": "ds_equip_hours",
      "displayName": "장비별 운전시간",
      "queryLines": [
        "SELECT equipment_name, operating_hours FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master ORDER BY operating_hours DESC"
      ]
    },
    {
      "name": "ds_equip_max_vib",
      "displayName": "장비별 최대 진동",
      "queryLines": [
        "SELECT e.equipment_name, ROUND(MAX(s.vibration_rms), 2) as max_vibration FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.equipment_name ORDER BY max_vibration DESC"
      ]
    },
    {
      "name": "ds_equip_press",
      "displayName": "장비별 압력",
      "queryLines": [
        "SELECT e.equipment_name, ROUND(AVG(s.pressure_bar), 1) as avg_pressure FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.equipment_name ORDER BY avg_pressure"
      ]
    },
    {
      "name": "ds_crit_vib",
      "displayName": "중요도별 진동",
      "queryLines": [
        "SELECT e.criticality, ROUND(AVG(s.vibration_rms), 2) as avg_vibration FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.criticality ORDER BY CASE e.criticality WHEN '핵심' THEN 1 WHEN '중요' THEN 2 ELSE 3 END"
      ]
    },
    {
      "name": "ds_line_vib",
      "displayName": "라인별 진동",
      "queryLines": [
        "SELECT e.line, ROUND(AVG(s.vibration_rms), 2) as avg_vibration FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY e.line ORDER BY avg_vibration DESC"
      ]
    },
    {
      "name": "ds_vibration_trend",
      "displayName": "진동 추이",
      "queryLines": [
        "SELECT equipment_id, DATE(timestamp) as dt, ROUND(AVG(vibration_rms), 2) as avg_vib FROM ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings GROUP BY equipment_id, DATE(timestamp) ORDER BY dt"
      ]
    },
    {
      "name": "ds_temp_trend",
      "displayName": "온도 추이",
      "queryLines": [
        "SELECT equipment_id, DATE(timestamp) as dt, ROUND(AVG(temperature_c), 1) as avg_temp FROM ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings GROUP BY equipment_id, DATE(timestamp) ORDER BY dt"
      ]
    },
    {
      "name": "ds_anomaly_hour",
      "displayName": "시간대별 이상",
      "queryLines": [
        "SELECT HOUR(timestamp) as hr, COUNT(*) as cnt FROM ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings WHERE vibration_rms > 7.0 OR temperature_c > 75.0 GROUP BY HOUR(timestamp) ORDER BY hr"
      ]
    },
    {
      "name": "ds_scatter",
      "displayName": "진동vs온도",
      "queryLines": [
        "SELECT e.equipment_name, e.criticality, ROUND(AVG(s.vibration_rms), 2) as avg_vib, ROUND(AVG(s.temperature_c), 1) as avg_temp FROM ebay_anomaly_detection_catalog.predictive_maintenance.equipment_master e JOIN ebay_anomaly_detection_catalog.predictive_maintenance.sensor_readings s ON e.equipment_id = s.equipment_id GROUP BY ALL"
      ]
    }
  ],
